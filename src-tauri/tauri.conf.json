{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "RPG Task Board",
  "version": "0.3.1",
  "identifier": "com.rpgtaskboard.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RPG Task Board",
        "width": 500,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "minWidth": 200,
        "minHeight": 60,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "publisher": "RPG Task Board",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "installerHeaderIcon": "icons/icon.ico",
        "language": "English",
        "displayLanguageSelector": false,
        "displayName": "RPG Task Board",
        "displayVersion": "0.3.1",
        "welcomeTitle": "RPG Task Board Setup",
        "welcomeMessage": "Welcome to RPG Task Board!\n\nA VPET-style RPG Task Board overlay for Windows.",
        "license": null,
        "headerColor": "#2a1a0e"
      }
    },
    "copyright": "Copyright (c) 2024 RPG Task Board",
    "category": "Utility"
  }
}